<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FAQ - Cyber Trust Bank</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen flex flex-col">
    <header class="bg-white shadow-md py-4 px-8 flex justify-between items-center">
        <a href="index.jsp" class="text-2xl font-bold text-blue-700 flex items-center space-x-2">
            <i class="fas fa-university text-blue-700 text-3xl"></i>
            <span>Cyber Trust Bank</span>
        </a>
        <nav>
            <a href="index.jsp" class="text-gray-700 hover:text-blue-600 mx-3">Home</a>
            <a href="about.jsp" class="text-gray-700 hover:text-blue-600 mx-3">About Us</a>
            <a href="faq.jsp" class="text-blue-700 font-bold mx-3">FAQ</a>
            <a href="contact.jsp" class="text-gray-700 hover:text-blue-600 mx-3">Contact</a>
        </nav>
    </header>
    <main class="flex-1 container mx-auto px-6 py-12">
        <section class="mb-12 text-center">
            <h1 class="text-4xl font-bold text-blue-700 mb-4">Frequently Asked Questions</h1>
            <p class="text-lg text-gray-700 max-w-2xl mx-auto">Find answers to the most common questions about Cyber Trust Bank's services, security, and support.</p>
        </section>
        <section class="max-w-2xl mx-auto">
            <div class="space-y-6">
                <div class="bg-white rounded-lg shadow-md p-6">
                    <h2 class="text-lg font-semibold text-blue-700 mb-2">How do I open an account with Cyber Trust Bank?</h2>
                    <p class="text-gray-700">You can open an account online by clicking the Sign Up button on our homepage and filling out the registration form.</p>
                </div>
                <div class="bg-white rounded-lg shadow-md p-6">
                    <h2 class="text-lg font-semibold text-blue-700 mb-2">Is my personal and financial information secure?</h2>
                    <p class="text-gray-700">Absolutely. We use advanced encryption and security protocols to protect your data at all times.</p>
                </div>
                <div class="bg-white rounded-lg shadow-md p-6">
                    <h2 class="text-lg font-semibold text-blue-700 mb-2">How can I contact customer support?</h2>
                    <p class="text-gray-700">You can reach our 24/7 support team via the Contact Us page or by submitting a support ticket through your account dashboard.</p>
                </div>
                <div class="bg-white rounded-lg shadow-md p-6">
                    <h2 class="text-lg font-semibold text-blue-700 mb-2">Are there any fees for online transactions?</h2>
                    <p class="text-gray-700">No, Cyber Trust Bank offers zero-fee online transactions for all customers.</p>
                </div>
                <div class="bg-white rounded-lg shadow-md p-6">
                    <h2 class="text-lg font-semibold text-blue-700 mb-2">How do I reset my password?</h2>
                    <p class="text-gray-700">Click the 'Forgot Password' link on the login page and follow the instructions to reset your password securely.</p>
                </div>
            </div>
        </section>
    </main>
    <footer class="bg-black text-white py-6 text-center mt-12">
        <p>&copy; 2025 Cyber Trust Bank. All rights reserved.</p>
    </footer>
</body>
</html> 